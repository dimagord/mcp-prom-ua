{
  "name": "prom-ua-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for prom.ua marketplace API — manage orders, products and messages",
  "main": "dist/index.js",
  "bin": {
    "prom-ua-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:express --external:axios --external:zod --external:@modelcontextprotocol/sdk",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.3.0"
  }
}
